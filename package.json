{
  "name": "@lifeforge/lifeforge--scores-library",
  "displayName": "Scores Library",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifeforge-app/lifeforge-module-scoresLibrary.git"
  },
  "version": "0.0.5",
  "type": "module",
  "author": "Melvin Chia <melvinchia623600@gmail.com>",
  "description": "Easily save and organize your music scores.",
  "scripts": {
    "typecheck": "pnpm run typecheck:client && pnpm run typecheck:server",
    "typecheck:client": "cd client && tsc",
    "typecheck:server": "cd server && tsc",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "cd server && vite build"
  },
  "dependencies": {
    "jsdom": "^27.0.0",
    "pdf-page-counter": "^1.0.3",
    "pdf-thumbnail": "^1.0.6",
    "pdfkit": "^0.17.2",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/pdf-thumbnail": "^1.0.4",
    "@types/pdfkit": "^0.17.3"
  },
  "lifeforge": {
    "icon": "tabler:file-music",
    "category": "Storage",
    "APIKeyAccess": {
      "deepseek": {
        "usage": "Cleanup scores name",
        "required": false
      }
    }
  },
  "peerDependencies": {
    "@lifeforge/api": "workspace:*",
    "@lifeforge/configs": "workspace:*",
    "@lifeforge/federation": "workspace:*",
    "@lifeforge/localization": "workspace:*",
    "@lifeforge/pocketbase": "workspace:*",
    "@lifeforge/server-utils": "workspace:*",
    "@lifeforge/ui": "workspace:*"
  }
}
